OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# Optional OpenRouter attribution headers (HTTP-Referer / X-Title). Defaults
# in auditor.py are fine for local demo.
# OPENROUTER_SITE_URL=http://localhost:5173
# OPENROUTER_SITE_NAME=Hardware Hub Booksy

# Any long, random string - used to sign session tokens (see auth.py). If
# left blank, the server generates a random one at startup (fine for local
# dev, but it means every restart logs everyone out); set a real value here
# for stable sessions / anything beyond local dev.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=